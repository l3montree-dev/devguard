{
    "component-definition": {
        "uuid": "75aaad5c-aa0d-4396-8cf0-44e64df712b5",
        "metadata": {
            "title": "DevGuard",
            "last-modified": "2026-04-15T00:00:00.000000+02:00",
            "version": "1.0.0",
            "oscal-version": "1.2.1"
        },
        "components": [
            {
                "uuid": "7f5f1b2c-cf17-4721-809c-054d6365b2c0",
                "type": "software",
                "title": "DevGuard",
                "description": "DevGuard is an open-source developer security platform (AGPL-3.0) that hardens the software supply chain. It continuously generates SBOMs for every build, monitors deployed software for newly disclosed CVEs, blocks malicious packages via a dependency firewall (npm, Go, Python), and exchanges vulnerability assessments using the VEX standard. It integrates with GitLab and GitHub CI pipelines.",
                "props": [
                    {
                        "name": "Rule_Id",
                        "ns": "http://oscal-compass.github.io/compliance-trestle/schemas/oscal/cd",
                        "value": "devguard_sbom_generated",
                        "remarks": "rule_set_0"
                    },
                    {
                        "name": "Rule_Description",
                        "ns": "http://oscal-compass.github.io/compliance-trestle/schemas/oscal/cd",
                        "value": "Verify that DevGuard generates and publishes a CycloneDX or SPDX SBOM for every pipeline build to the configured artifact URL.",
                        "remarks": "rule_set_0"
                    },
                    {
                        "name": "Parameter_Id",
                        "ns": "http://oscal-compass.github.io/compliance-trestle/schemas/oscal/cd",
                        "value": "sbom-artifact-url",
                        "remarks": "rule_set_0"
                    },
                    {
                        "name": "Parameter_Description",
                        "ns": "http://oscal-compass.github.io/compliance-trestle/schemas/oscal/cd",
                        "value": "URL at which the generated SBOM artifact is published and retrievable (e.g. https://devguard.example.com/api/v1/projects/my-app/sbom.json).",
                        "remarks": "rule_set_0"
                    },
                    {
                        "name": "Rule_Id",
                        "ns": "http://oscal-compass.github.io/compliance-trestle/schemas/oscal/cd",
                        "value": "devguard_dependency_firewall_active",
                        "remarks": "rule_set_1"
                    },
                    {
                        "name": "Rule_Description",
                        "ns": "http://oscal-compass.github.io/compliance-trestle/schemas/oscal/cd",
                        "value": "Verify that the DevGuard dependency firewall is active and blocking known malicious or vulnerable packages across all configured ecosystems.",
                        "remarks": "rule_set_1"
                    },
                    {
                        "name": "Rule_Id",
                        "ns": "http://oscal-compass.github.io/compliance-trestle/schemas/oscal/cd",
                        "value": "devguard_dependency_source_verified",
                        "remarks": "rule_set_2"
                    },
                    {
                        "name": "Rule_Description",
                        "ns": "http://oscal-compass.github.io/compliance-trestle/schemas/oscal/cd",
                        "value": "Verify that DevGuard enforces an allowlist of trusted package registries and blocks resolution from unknown or untrusted sources.",
                        "remarks": "rule_set_2"
                    }
                ],
                "control-implementations": [
                    {
                        "uuid": "c1f8e45b-181d-4ad2-9648-e1e2f90ca4f7",
                        "source": "Grundschutz++",
                        "description": "Control implementation for DevGuard supply chain security.",
                        "implemented-requirements": [
                            {
                                "uuid": "e82ac899-3ec2-4250-b558-350da22aa457",
                                "control-id": "DEV.4.3",
                                "description": "DevGuard generates a CycloneDX SBOM for every CI pipeline build, capturing all direct and transitive dependencies with their versions and known CVEs. The SBOM is signed and published to the artifact registry endpoint defined by the sbom-artifact-url parameter, making it retrievable for downstream consumers and auditors.",
                                "set-parameters": [
                                    {
                                        "param-id": "sbom-artifact-url",
                                        "values": [
                                            "https://devguard.example.com/api/v1/projects/my-app/sbom.json"
                                        ]
                                    }
                                ],
                                "props": [
                                    {
                                        "name": "Rule_Id",
                                        "ns": "http://oscal-compass.github.io/compliance-trestle/schemas/oscal/cd",
                                        "value": "devguard_sbom_generated"
                                    }
                                ]
                            },
                            {
                                "uuid": "1b2c3d4e-5f6a-4b8c-8d0e-1f2a3b4c5d6e",
                                "control-id": "DEV.4.2",
                                "description": "DevGuard's dependency firewall restricts package resolution to a configured set of trusted registries. Any attempt to pull a dependency from an unknown or untrusted source is blocked at the network level during the CI build, ensuring that only vetted supply chain sources are used.",
                                "props": [
                                    {
                                        "name": "Rule_Id",
                                        "ns": "http://oscal-compass.github.io/compliance-trestle/schemas/oscal/cd",
                                        "value": "devguard_dependency_source_verified"
                                    }
                                ]
                            },
                            {
                                "uuid": "3a9f4b81-2c7d-4e56-a934-6d1e2f80cb39",
                                "control-id": "DEV.4.4",
                                "description": "DevGuard's dependency firewall intercepts package resolution requests at build time and blocks packages that are listed as malicious or critically vulnerable across its database (OpenSSF Malicious Packages Database). It covers npm, Go, and Python ecosystems. Any blocked package causes the pipeline to fail, preventing compromised dependencies from entering the build.",
                                "props": [
                                    {
                                        "name": "Rule_Id",
                                        "ns": "http://oscal-compass.github.io/compliance-trestle/schemas/oscal/cd",
                                        "value": "devguard_dependency_firewall_active"
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
