    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Daemon Pipeline",
            "type": "go",
            "request": "launch",
            "cwd": "${workspaceRoot}",
            "mode": "auto",
            "program": "${workspaceRoot}/cmd/devguard-cli/main.go",
            "args": [
                "daemon",
                "trigger",
                "--daemons",
                "assetPipeline"
            ],
        },
        {
            "name": "Launch specific Daemon Pipeline",
            "type": "go",
            "request": "launch",
            "cwd": "${workspaceRoot}",
            "mode": "auto",
            "program": "${workspaceRoot}/cmd/devguard-cli/main.go",
            "args": [
                "daemon",
                "runPipeline",
                "4381b801-2b27-4569-bba6-5a14591e4eb5",
                "--assetVersionSlug",
                "develop"
            ],
        },
        {
            "name": "Launch Server",
            "type": "go",
            "request": "launch",
            "cwd": "${workspaceRoot}",
            "mode": "auto",
            "program": "${workspaceRoot}/cmd/devguard/main.go",
            "args": [],
        },
    {
        "name": "Launch DepTreeWalk",
        "type": "go",
        "request": "launch",
        "cwd": "${workspaceRoot}",
        "mode": "auto",
        "program": "${workspaceRoot}/cmd/devguard-cli/test",
        "args": [
        ],
    },
        {
            "name": "Launch Policy eval",
            "type": "go",
            "request": "launch",
            "cwd": "${workspaceRoot}",
            "mode": "auto",
            "program": "${workspaceRoot}/cmd/devguard-scanner/main.go",
            "args": [
                "attestations",
                "registry.opencode.de/open-code/oci/coreutils:1.0.0-rc.3-minimal-amd64",
                "--policy",
                "container.gov.de.rego"
            ],
        },
        {
            "name": "Launch Server with Prod Database",
            "type": "go",
            "request": "launch",
            "cwd": "${workspaceRoot}",
            "mode": "auto",
            "program": "${workspaceRoot}/cmd/devguard/main.go",
            "args": [],
            "env": {
                "DISABLE_AUTOMIGRATE": "true",
                "POSTGRES_PORT": "5433"
            }
        },
        {
            "name": "VulnDB Export Diffs",
            "type": "go",
            "request": "launch",
            "cwd": "${workspaceRoot}",
            "mode": "auto",
            "program": "${workspaceRoot}/cmd/devguard-cli/main.go",
            "args": [
                "vulndb",
                "export",
            ],
        },
        {
            "name": "VulnDB Sync",
            "type": "go",
            "request": "launch",
            "cwd": "${workspaceRoot}",
            "mode": "auto",
            "program": "${workspaceRoot}/cmd/devguard-cli/main.go",
            "args": [
                "vulndb",
                "sync",
                "--databases",
                "epss"
            ]
        },
        {
            "name": "Scanner attestations",
            "type": "go",
            "request": "launch",
            "cwd": "${workspaceRoot}",
            "mode": "auto",
            "program": "${workspaceRoot}/cmd/devguard-scanner/main.go",
            "args": [
                "attestations",
                "registry.opencode.de/l3montree/test-container-gov-attestations:main-amd64",
                "--policy",
                "https://gitlab.opencode.de/oci-community/container-gov/-/raw/main/data-generation/container.gov.de.rego"
            ]
        },
    ]
}